generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
}

enum LicenseStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  PIX
  BOLETO
}

model User {
  id           String     @id @default(cuid())
  name         String     @db.VarChar(160)
  email        String     @unique @db.VarChar(191)
  passwordHash String     @db.VarChar(255)
  role         UserRole   @default(OPERATOR)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  sessions     Session[]
}

model Client {
  id              String         @id @default(cuid())
  name            String         @db.VarChar(160)
  nameNormalized  String         @db.VarChar(191)
  company         String?        @db.VarChar(160)
  phone           String         @db.VarChar(20)
  phoneNormalized String         @db.VarChar(20)
  cpf             String         @db.VarChar(14)
  cpfDigits       String         @db.Char(11)
  photoUrl        String?        @db.MediumText
  clientType      String?        @db.VarChar(30)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  vehicles        Vehicle[]
  registrations   Registration[]

  @@index([nameNormalized])
  @@index([phoneNormalized])
  @@index([cpfDigits])
}

model Vehicle {
  id              String         @id @default(cuid())
  clientId        String
  plate           String         @db.VarChar(8)
  plateNormalized String         @db.Char(7)
  brandModel      String?        @db.VarChar(160)
  color           String?        @db.VarChar(60)
  category        String?        @db.VarChar(60)
  photoUrl        String?        @db.MediumText
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  registrations   Registration[] @relation("RegVehicle1")
  registrations2  Registration[] @relation("RegVehicle2")

  @@index([clientId])
  @@index([plateNormalized])
}

model Registration {
  id             String             @id @default(cuid())
  clientId       String
  vehicleId      String
  vehicle2Id     String?
  cardNumber     String?            @unique @db.VarChar(50)
  trSl           String?            @db.VarChar(50)
  status         RegistrationStatus @default(ACTIVE)
  observations   String?            @db.Text
  declarationUrl String?            @db.MediumText
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle        Vehicle            @relation("RegVehicle1", fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle2       Vehicle?           @relation("RegVehicle2", fields: [vehicle2Id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clientId])
  @@index([vehicleId])
  @@index([vehicle2Id])
}

model Configuration {
  id                             Int      @id @default(1)
  allowMultipleVehiclesPerClient Boolean  @default(false)
  sessionDurationDays            Int      @default(7)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model License {
  id              String        @id @default(cuid())
  status          LicenseStatus @default(TRIAL)
  expiresAt       DateTime
  asaasCustomerId String?       @db.VarChar(191)
  holderName      String?       @db.VarChar(160)
  holderCpf       String?       @db.VarChar(14)
  holderEmail     String?       @db.VarChar(191)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments        LicensePayment[]
}

model LicensePayment {
  id             String        @id @default(cuid())
  licenseId      String
  asaasPaymentId String        @unique @db.VarChar(191)
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  daysAdded      Int           @default(30)
  pixQrCode      String?       @db.Text
  pixCopyPaste   String?       @db.Text
  boletoUrl      String?       @db.Text
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  license        License       @relation(fields: [licenseId], references: [id])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique @db.Char(64)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ip         String?   @db.VarChar(64)
  userAgent  String?   @db.VarChar(512)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, expiresAt, revokedAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       AuditAction
  entity       String      @db.VarChar(80)
  entityId     String      @db.VarChar(191)
  previousData Json?
  newData      Json?
  ip           String?     @db.VarChar(64)
  userAgent    String?     @db.VarChar(512)
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([entity, entityId])
  @@index([createdAt])
}
