generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
}

model User {
  id           String     @id @default(cuid())
  name         String     @db.VarChar(160)
  email        String     @unique @db.VarChar(191)
  passwordHash String     @db.VarChar(255)
  role         UserRole   @default(OPERATOR)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  sessions     Session[]
}

model Client {
  id              String         @id @default(cuid())
  name            String         @db.VarChar(160)
  nameNormalized  String         @db.VarChar(191)
  phone           String         @db.VarChar(20)
  phoneNormalized String         @db.VarChar(20)
  cpf             String         @db.VarChar(14)
  cpfDigits       String         @unique @db.Char(11)
  photoUrl        String?        @db.MediumText
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  vehicles        Vehicle[]
  registrations   Registration[]

  @@index([nameNormalized])
  @@index([phoneNormalized])
}

model Vehicle {
  id              String         @id @default(cuid())
  clientId        String
  plate           String         @db.VarChar(8)
  plateNormalized String         @unique @db.Char(7)
  brandModel      String?        @db.VarChar(160)
  color           String?        @db.VarChar(60)
  category        String?        @db.VarChar(60)
  photoUrl        String?        @db.MediumText
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  registrations   Registration[]

  @@index([clientId])
}

model Registration {
  id           String             @id @default(cuid())
  clientId     String
  vehicleId    String
  cardNumber   String?            @unique @db.VarChar(50)
  trSl         String?            @db.VarChar(50)
  status       RegistrationStatus @default(ACTIVE)
  observations String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle      Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clientId])
  @@index([vehicleId])
}

model Configuration {
  id                             Int      @id @default(1)
  allowMultipleVehiclesPerClient Boolean  @default(false)
  sessionDurationDays            Int      @default(7)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique @db.Char(64)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  ip         String?   @db.VarChar(64)
  userAgent  String?   @db.VarChar(512)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, expiresAt, revokedAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       AuditAction
  entity       String      @db.VarChar(80)
  entityId     String      @db.VarChar(191)
  previousData Json?
  newData      Json?
  ip           String?     @db.VarChar(64)
  userAgent    String?     @db.VarChar(512)
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([entity, entityId])
  @@index([createdAt])
}
